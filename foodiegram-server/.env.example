# FoodieGram Backend - Environment Variables
# Copy this file to ".env" and fill in real values

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- PostgreSQL (Prisma) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/foodiegram?schema=public"

# --- JWT Auth ---
JWT_SECRET=CHANGE_ME_long_random_secret_string
JWT_EXPIRES_IN=7d

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
